# Neon Postgres: Neon dashboard → Connect → Connection string
DATABASE_URL=postgresql://username:password@your-neon-host/neondb?sslmode=require

# Resend: API Keys → Create API Key (Sending access is sufficient)
RESEND_API_KEY=re_replace_with_your_resend_api_key

# The private address that receives each new website enquiry
ENQUIRY_TO_EMAIL=owner@example.com

# Must use a sender/domain that you have verified in Resend
ENQUIRY_FROM_EMAIL="Andrew's Garage <enquiries@yourdomain.co.uk>"

# Generate a unique random value containing at least 32 characters
RATE_LIMIT_SALT=replace-with-at-least-32-random-characters
